.DS_Store
*.env
.env.*
node_modules/
__pycache__/
*.pyc

# Local settings with API keys and personal paths — never commit
.claude/settings.local.json

# Private athlete content — everything in private/ is local only, never commit
# Any new file added to private/ is automatically ignored — no need to list individually
private/agents/**
private/skills/**
private/config/**
private/data/**
!private/data/sessions/template.md
!private/**/.gitkeep
